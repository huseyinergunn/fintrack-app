// Fintrack — Prisma Schema
// Prisma, DATABASE_URL'i doğrudan okur — asyncpg prefix'i yok, sadece postgresql://

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Neon pooler bypass — migration için gerekli
}

// ── Kullanıcı (şirket sahibi veya çalışan) ───────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String?  @map("full_name")
  companyName  String?  @map("company_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  clients          Client[]
  invoices         Invoice[]
  expenses         Expense[] @relation("UserExpenses")
  approvedExpenses Expense[] @relation("ApprovedExpenses")

  @@map("users")
}

// ── Müşteri (örn: Kozan Ajans) ────────────────────────────────────────────────
model Client {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  email     String?
  phone     String?
  address   String?
  taxNumber String?  @map("tax_number")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([userId])
  @@map("clients")
}

// ── Fatura durumu ─────────────────────────────────────────────────────────────
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ── Fatura (örn: Ayşe'nin Kozan Ajans'a kestiği fatura) ──────────────────────
model Invoice {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  clientId      String?       @map("client_id")
  invoiceNumber String        @unique @map("invoice_number") // INV-2026-0001
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @map("issue_date")
  dueDate       DateTime      @map("due_date")
  subtotal      Decimal       @db.Decimal(12, 2)
  taxRate       Decimal       @default(20) @db.Decimal(5, 2) @map("tax_rate")
  taxAmount     Decimal       @db.Decimal(12, 2) @map("tax_amount")
  total         Decimal       @db.Decimal(12, 2)
  notes         String?
  pdfUrl        String?       @map("pdf_url")
  paidAt        DateTime?     @map("paid_at")
  isDeleted     Boolean       @default(false) @map("is_deleted")
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lineItems LineItem[]

  @@index([userId, isDeleted])
  @@index([userId, isDeleted, status])
  @@index([userId, isDeleted, dueDate])
  @@index([userId, isDeleted, paidAt])
  @@map("invoices")
}

// ── Fatura kalemi (örn: Logo Tasarımı × 1 = 5.000 ₺) ────────────────────────
model LineItem {
  id          String  @id @default(uuid())
  invoiceId   String  @map("invoice_id")
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2) @map("unit_price")
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("line_items")
}

// ── Gider kategorisi ──────────────────────────────────────────────────────────
enum ExpenseCategory {
  OFFICE
  SOFTWARE
  FOOD
  TRANSPORT
  UTILITY
  OTHER
}

// ── Gider onay durumu ─────────────────────────────────────────────────────────
enum ExpenseStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAID
}

// ── Gider (örn: Mehmet'in Migros fişi) ───────────────────────────────────────
model Expense {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  category    ExpenseCategory @default(OTHER)
  vendor      String?
  amount      Decimal         @db.Decimal(12, 2)
  taxAmount   Decimal?        @db.Decimal(12, 2) @map("tax_amount")
  expenseDate DateTime        @map("expense_date")
  status      ExpenseStatus   @default(PENDING_APPROVAL)
  receiptUrl  String?         @map("receipt_url")
  ocrRaw      Json?           @map("ocr_raw") // Gemini'nin ham yanıtı — debug için
  notes       String?
  dueDate     DateTime?       @map("due_date")
  approvedBy  String?         @map("approved_by")
  approvedAt  DateTime?       @map("approved_at")
  isDeleted   Boolean         @default(false) @map("is_deleted")
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user     User  @relation("UserExpenses", fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("ApprovedExpenses", fields: [approvedBy], references: [id])

  @@index([userId, isDeleted])
  @@index([userId, isDeleted, status])
  @@index([userId, isDeleted, expenseDate])
  @@index([userId, isDeleted, dueDate])
  @@map("expenses")
}
